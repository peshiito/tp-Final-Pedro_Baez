# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# MYSQL DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=patitas_felices_db  

# ============================================
# JWT
# ============================================
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# BCRYPT
# ============================================
BCRYPT_ROUNDS=10

# ============================================
# API
# ============================================
API_PREFIX=/api
CORS_ORIGIN=*