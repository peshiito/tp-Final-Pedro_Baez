# ============================================
# SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# BASE DE DATOS MYSQL
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ============================================
# JWT
# ============================================
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# BCRYPT
# ============================================
BCRYPT_ROUNDS=10

# ============================================
# API
# ============================================
API_PREFIX=/api
CORS_ORIGIN=*